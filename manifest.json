{
  "manifest_version": 3,
  "name": "Kinetics",
  "description": "A strict 90-minute productivity timer that enforces the Cornell 20-8-2 ergonomic posture protocol using in-browser notifications.",
  "version": "2.0.0",
  "author": "RubarMo",
  "permissions": [
    "alarms",
    "storage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
